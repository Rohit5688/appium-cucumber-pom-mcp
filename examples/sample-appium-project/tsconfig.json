{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node",
      "@wdio/globals/types",
      "@wdio/cucumber-framework",
      "@wdio/appium-service"
    ]
  },
  "include": [
    "src/**/*.ts",
    "wdio.conf.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "reports"
  ]
}