{
  "name": "appforge",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "description": "Enterprise-grade MCP Server for orchestrated mobile automation (Android/iOS) using WebdriverIO and Cucumber BDD.",
  "author": "ForgeTest AI",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/ForgeTest-AI/AppForge.git"
  },
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs => fs.cpSync('src/skills', 'dist/skills', {recursive: true}))\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "pretest": "tsc",
    "test": "node --test dist/tests/",
    "test:watch": "node --test --watch src/tests/",
    "build:macos": "pkg . --targets node18-macos-arm64,node18-macos-x64 --out-path binaries",
    "build:win": "pkg . --targets node18-win-x64 --out-path binaries"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "appium",
    "webdriverio",
    "cucumber",
    "mobile-automation",
    "ai",
    "qa"
  ],
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.92",
    "@cucumber/cucumber": "^12.7.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "ts-morph": "^27.0.2",
    "webdriverio": "^9.26.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@wdio/cli": "^9.27.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
